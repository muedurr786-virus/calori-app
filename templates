------------auth-----------


<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md border border-gray-200">
    <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">
        {{ title }}{{ Form_titel }}
    </h2>
    
    <form method="POST" enctype="multipart/form-data" class="space-y-4">
        {% csrf_token %}
        
        <div class="space-y-2 text-gray-700">
            {{ form.as_p }}
        </div>
        
        <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded transition duration-200">
            {{ btn }}{{ btn_title }}
        </button>
    </form>

    <div class="mt-6 text-center text-sm text-gray-600">
        {% if Form_titel == "Login Page" or title == "Login Page" %}
            <a href="{% url 'register' %}" class="text-blue-500 hover:underline font-semibold">Register</a>
        {% elif Form_titel == "Register Page" or title == "Register Page" %}
            <a href="{% url 'login' %}" class="text-blue-500 hover:underline font-semibold">Login</a>
        {% endif %}
    </div>
</div>


